# Copy to .env and adjust. .env is gitignored; this file is the committed contract.

# ---- PostgreSQL (used by docker compose and the API) ----
POSTGRES_USER=app
POSTGRES_PASSWORD=app_dev_password
POSTGRES_DB=app
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Full URL the API uses. Host is "db" inside compose, "localhost" on the host.
DATABASE_URL=postgresql+psycopg://app:app_dev_password@db:5432/app

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
# Comma-separated origins allowed by CORS.
CORS_ORIGINS=http://localhost:5173

# ---- Web ----
# Base URL the browser uses to reach the API.
VITE_API_URL=http://localhost:8000
